# Copy this file and fill in your values:  cp .env.example .env

# ─── Nginx (reverse proxy — single public entry point) ───────────────────────
# All services are routed through port 80. Admin tools (/pgadmin, /splunk) are
# protected by HTTP Basic Auth using these credentials.
NGINX_PORT=80
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=your_nginx_admin_password

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Shared by application services. Keycloak now uses its own DB in auth-service.
# Bound to 127.0.0.1 — accessible from the host for psql/pgAdmin desktop clients.
POSTGRES_USER=society_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PORT=5432

# ─── Keycloak (centralized auth-service at ~/auth-service) ───────────────────
# Keycloak is hosted by the centralized auth-service and exposed publicly at
# https://auth.gm-global-techies-town.club via its Cloudflare tunnel.
# KEYCLOAK_URL  — backend service-to-service URL (can use the public HTTPS URL)
# KEYCLOAK_PUBLIC_URL — browser-facing URL (same as KEYCLOAK_URL for centralized setup)
# KEYCLOAK_ADMIN_USER / PASSWORD — master-realm admin credentials from auth-service .env
KEYCLOAK_URL=https://auth.gm-global-techies-town.club
KEYCLOAK_PUBLIC_URL=https://auth.gm-global-techies-town.club
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password
KEYCLOAK_API_CLIENT_SECRET=your_keycloak_api_client_secret_min_32_chars

# ─── Google OAuth — OPTIONAL (Social Login via Keycloak) ─────────────────────
# Configure in the auth-service Keycloak admin UI (https://auth.gm-global-techies-town.club/admin).
# Authorised redirect URI: https://auth.gm-global-techies-town.club/realms/society-events/broker/google/endpoint
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── pgAdmin 4 (Database GUI — served at /pgadmin/) ──────────────────────────
# Has NO host port — accessed through nginx (nginx basic auth required first).
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password

# ─── Redis ────────────────────────────────────────────────────────────────────
# Bound to 127.0.0.1 only — accessible from the host for debugging but not publicly exposed.
# REDIS_PASSWORD is optional: leave blank to run Redis without authentication (local dev only).
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# ─── Application Services ─────────────────────────────────────────────────────
# Shared secret for internal service-to-service calls. Use a long random string.
INTERNAL_API_KEY=your_internal_api_key_min_32_chars

# ─── Society Configuration ────────────────────────────────────────────────────
SOCIETY_NAME=Your Society Name
SOCIETY_SHORT_NAME=YSN
SOCIETY_CITY=Your City

# ─── Gmail SMTP — OPTIONAL (Keycloak outbound email) ─────────────────────────
# Configure SMTP in the auth-service Keycloak admin UI, or run: make setup-email
# which calls the Keycloak Admin API at KEYCLOAK_URL.
# Generate an App Password at https://myaccount.google.com/apppasswords (2FA required).
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=

# ─── Splunk — OPTIONAL (centralized ~/splunk-service) ────────────────────────
# Splunk runs as a separate centralized service — start it with: make splunk-up
# Web UI: https://splunk.gm-global-techies-town.club
# HEC endpoint (services ship events here): http://localhost:8088
#
# SPLUNK_HEC_TOKEN — shared token used by all services and Fluent Bit to ship
#   events to the HEC at host.containers.internal:8088. Leave blank to disable
#   all log shipping (services remain fully functional without Splunk).
# Copy the token value from ~/splunk-service/.env (SPLUNK_HEC_TOKEN).
SPLUNK_HEC_TOKEN=

# ─── Claude API (Anthropic) — OPTIONAL ────────────────────────────────────────
# Used by the payment service's IMAP email parser as an alternative to Ollama.
# Select it per-deployment via ai_provider="claude" in PUT /settings (payment
# service) — this key only takes effect when that setting is chosen. Leave
# blank to use Ollama/regex only.
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Payment service test mode — OPTIONAL ─────────────────────────────────────
# "testing" mounts extra /api/payments/test/* endpoints (clear-transactions,
# seed-transaction) used to exercise the centralized reconciliation service's
# /parseEmail without a real checkout. Leave as "production" everywhere else —
# these endpoints must never be reachable in a real deployment.
PAYMENT_SERVICE_ENV=production

# ─── OTP Bridge Service ───────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
OTP_BRIDGE_CLIENT_SECRET=

# SMS Gateway: "auth_service" (recommended — see below), "fast2sms" (cloud, paid),
# "log" (dev — prints to stdout), "gammu" (USB modem), "httpsms", "disabled"
SMS_GATEWAY=log

# ── Auth-service gateway (recommended — free, self-hosted, no hardware) ──────
# Uses the centralized auth-service's committee-phone failover fleet (Android
# phones running the open-source SMS Gateway app, reached over Tailscale — see
# ~/auth-service's sms_gateways table to add/rotate phones). Set:
#   SMS_GATEWAY=auth_service
#   AUTH_SERVICE_API_KEY=<same value as auth-service's OTP_SERVICE_API_KEY>
# AUTH_SERVICE_SMS_URL defaults to http://host.containers.internal:8000/api/sms/send
# (auth-service's backend on the same host) — only override if that changes.
AUTH_SERVICE_API_KEY=

# ── HTTP SMS gateway (no USB cable — Android app over Wi-Fi) ─────────────────
# Install "Android SMS Gateway" app on your Android phone (free, open-source):
#   Play Store → search "SMS Gateway" by capcom6
#   GitHub     → https://github.com/capcom6/android-sms-gateway
# Steps:
#   1. Install app → tap "Start Server"
#   2. Copy the shown URL and API key into the vars below
#   3. Set SMS_GATEWAY=httpsms
#   4. Run: make restart-otp-service
# Both the phone and this machine must be on the same Wi-Fi (or use ngrok/Cloudflare for remote).
HTTP_SMS_URL=
HTTP_SMS_API_KEY=
HTTP_SMS_FROM=         # SIM number in the gateway phone, e.g. +919876543210

# ─── Frontend build mode ─────────────────────────────────────────────────────
# Controls which Vite build mode is used and whether debug panels are shown.
# dev/test: token debug panel visible. stage/prod: hidden.
VITE_MODE=production
VITE_APP_ENV=prod

# Gammu device path — only needed when SMS_GATEWAY=gammu.
# Check: ls /dev/ttyUSB* or ls /dev/ttyACM*
# Uncomment the 'devices' block in docker-compose.yml otp-service when using a modem.
# USB_MODEM_DEVICE=/dev/ttyUSB0
