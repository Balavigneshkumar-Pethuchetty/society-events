# Copy this file and fill in your values:  cp .env.example .env

# ─── Nginx (reverse proxy — single public entry point) ───────────────────────
# All services are routed through port 80. Admin tools (/pgadmin, /mail) are
# protected by HTTP Basic Auth using these credentials.
NGINX_PORT=8080
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=change_me

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Postgres has NO host port binding — only reachable inside the Docker network.
POSTGRES_USER=society_user
POSTGRES_PASSWORD=change_me

# ─── Keycloak ─────────────────────────────────────────────────────────────────
# Keycloak is served at http://<host>/auth/ through nginx.
# KC_HTTP_RELATIVE_PATH is set to /auth in docker-compose — do not change here.
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# ─── pgAdmin ──────────────────────────────────────────────────────────────────
# pgAdmin is served at http://<host>/pgadmin/ and requires nginx basic auth first.
PGADMIN_EMAIL=dev@society.com
PGADMIN_PASSWORD=change_me

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis has NO host port binding — only reachable inside the Docker network.
REDIS_PASSWORD=change_me

# ─── Mailpit ──────────────────────────────────────────────────────────────────
# SMTP is bound to 127.0.0.1 only (localhost). UI is at http://<host>/mail/ via nginx.
MAILPIT_SMTP_PORT=1025

# ─── Frontend (local dev server only) ────────────────────────────────────────
# Used by `make frontend` (Vite hot-reload). Not used when running in Docker.
FRONTEND_PORT=3000
