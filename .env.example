# Copy this file and fill in your values:  cp .env.example .env

# ─── Nginx (reverse proxy — single public entry point) ───────────────────────
# All services are routed through port 80. Admin tools (/pgadmin, /splunk) are
# protected by HTTP Basic Auth using these credentials.
NGINX_PORT=80
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=your_nginx_admin_password

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Shared by Keycloak, User Service, and Event Service.
# Bound to 127.0.0.1 — accessible from the host for psql/pgAdmin desktop clients.
POSTGRES_USER=society_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PORT=5432

# ─── Keycloak (Identity & Access Management) ─────────────────────────────────
# Keycloak is served at <KEYCLOAK_PUBLIC_URL>/auth/ through nginx.
# KEYCLOAK_PORT is the host port for the direct Keycloak admin UI (bypasses nginx).
# KEYCLOAK_PUBLIC_URL must be the externally reachable base URL (used in email links).
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password
KEYCLOAK_PUBLIC_URL=https://your-domain.com
KEYCLOAK_PORT=8081
KEYCLOAK_API_CLIENT_SECRET=your_keycloak_api_client_secret_min_32_chars

# ─── Google OAuth — OPTIONAL (Social Login via Keycloak) ─────────────────────
# Leave blank to disable the "Continue with Google" button on the login page.
# When set, run: make setup-google-idp   to enable it in the running Keycloak.
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials.
# Authorised redirect URI: <KEYCLOAK_PUBLIC_URL>/realms/society-events/broker/google/endpoint
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── pgAdmin 4 (Database GUI — served at /pgadmin/) ──────────────────────────
# Has NO host port — accessed through nginx (nginx basic auth required first).
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password

# ─── Redis ────────────────────────────────────────────────────────────────────
# Bound to 127.0.0.1 only — accessible from the host for debugging but not publicly exposed.
# REDIS_PASSWORD is optional: leave blank to run Redis without authentication (local dev only).
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# ─── Application Services ─────────────────────────────────────────────────────
# Shared secret for internal service-to-service calls. Use a long random string.
INTERNAL_API_KEY=your_internal_api_key_min_32_chars

# ─── Society Configuration ────────────────────────────────────────────────────
SOCIETY_NAME=Your Society Name
SOCIETY_SHORT_NAME=YSN
SOCIETY_CITY=Your City

# ─── Gmail SMTP — OPTIONAL (Keycloak outbound email) ─────────────────────────
# Required for password-reset and account-verification emails from Keycloak.
# Leave blank to disable email sending (users can still log in; self-service password
# reset via email will not work).
# Generate an App Password at https://myaccount.google.com/apppasswords (2FA required).
# After setting, run: make sync-keycloak-name   to apply to the running Keycloak.
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=

# ─── Splunk — OPTIONAL (monitoring profile only) ──────────────────────────────
# Only used when started with: docker compose --profile monitoring up -d splunk fluent-bit
# Leave all three blank to run the stack without log aggregation.
# Web UI: http://localhost:<SPLUNK_PORT>  (admin / $SPLUNK_PASSWORD)
SPLUNK_PORT=8000
SPLUNK_PASSWORD=
SPLUNK_HEC_TOKEN=
