# Test environment — offset ports so dev and test can run simultaneously
# Usage: make up ENV=test   |   make down ENV=test
# Copy:  cp .env.test.example .env.test

# ─── Nginx ───────────────────────────────────────────────────────────────────
NGINX_PORT=8180
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=test_admin_pass

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=society_user
POSTGRES_PASSWORD=test_pg_pass
POSTGRES_PORT=5433

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=test_kc_pass
KEYCLOAK_PUBLIC_URL=http://localhost:8180
KEYCLOAK_PORT=8181
KEYCLOAK_API_CLIENT_SECRET=test_api_client_secret_min_32_chars_xx

# ─── Google OAuth — OPTIONAL ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=test@local.test
PGADMIN_PASSWORD=test_pgadmin_pass

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=test_redis_pass
REDIS_PORT=6380

# ─── Application Services ─────────────────────────────────────────────────────
INTERNAL_API_KEY=test_internal_api_key_min_32_chars_xxxx

# ─── Society Configuration ────────────────────────────────────────────────────
SOCIETY_NAME=GM Global Techies Town (Test)
SOCIETY_SHORT_NAME=GMGT-TEST
SOCIETY_CITY=Bengaluru

# ─── Gmail SMTP — OPTIONAL ────────────────────────────────────────────────────
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=

# ─── Splunk — OPTIONAL ────────────────────────────────────────────────────────
SPLUNK_PORT=8100
SPLUNK_PASSWORD=
SPLUNK_HEC_TOKEN=

# ─── Payment service — encrypts per-event IMAP passwords at rest (committee_registry) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PAYMENT_SECRET_KEY=
