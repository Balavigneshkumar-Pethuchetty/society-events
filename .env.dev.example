# Development environment — local machine
# Usage: make up ENV=dev   |   make down ENV=dev
# Copy:  cp .env.dev.example .env.dev

# ─── Nginx ───────────────────────────────────────────────────────────────────
NGINX_PORT=8080
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=dev_admin_pass

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=society_user
POSTGRES_PASSWORD=dev_pg_pass
POSTGRES_PORT=5432

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=dev_kc_pass
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_PORT=8081
KEYCLOAK_API_CLIENT_SECRET=dev_api_client_secret_min_32_chars_xx

# ─── Google OAuth — OPTIONAL ──────────────────────────────────────────────────
# Leave blank → "Continue with Google" button hidden on login page.
# Set and run: make setup-google-idp ENV=dev
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=dev@local.dev
PGADMIN_PASSWORD=dev_pgadmin_pass

# ─── Redis ────────────────────────────────────────────────────────────────────
# REDIS_PASSWORD is optional — leave blank for no-auth Redis (local dev only).
REDIS_PASSWORD=dev_redis_pass
REDIS_PORT=6379

# ─── Application Services ─────────────────────────────────────────────────────
INTERNAL_API_KEY=dev_internal_api_key_min_32_chars_xxxx

# ─── Society Configuration ────────────────────────────────────────────────────
SOCIETY_NAME=GM Global Techies Town (Dev)
SOCIETY_SHORT_NAME=GMGT-DEV
SOCIETY_CITY=Bengaluru

# ─── Gmail SMTP — OPTIONAL ────────────────────────────────────────────────────
# Leave blank → email sending disabled (users can still log in).
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=

# ─── Splunk — OPTIONAL ────────────────────────────────────────────────────────
# Leave blank → monitoring profile skipped; app still runs normally.
SPLUNK_PORT=8000
SPLUNK_PASSWORD=
SPLUNK_HEC_TOKEN=
