        "http://localhost:4200",
        "http://localhost:5173",
        "http://localhost:8080",
        "http://192.168.1.11:8080",
        "http://192.168.1.11:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "society-api",
      "name": "Society Events \u2014 API Gateway",
      "description": "Confidential client for backend microservices to validate tokens",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "society-api-secret-change-in-prod",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
