        "http://localhost:4200/*",
        "http://localhost:5173/*",
        "http://localhost:8080/*",
        "http://192.168.1.11/*",
        "http://192.168.1.11:8080/*",
        "http://192.168.1.11:3000/*",
        "https://gm-global-techies-town.club/*",
        "https://www.gm-global-techies-town.club/*"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:3000",
        "http://localhost:3001",
        "http://localhost:4004",
        "http://localhost:4005",
        "http://localhost:4200",
        "http://localhost:5173",
        "http://localhost:8080",
        "http://192.168.1.11",
        "http://192.168.1.11:8080",
        "https://gm-global-techies-town.club",
        "https://www.gm-global-techies-town.club",
        "http://192.168.1.11:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "basic",
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "society-api",
      "name": "Society Events \u2014 API Gateway",
      "description": "Confidential client for backend microservices to validate tokens",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "${env.KEYCLOAK_API_CLIENT_SECRET}",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],
