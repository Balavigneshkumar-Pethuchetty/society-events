  "realm": "society-events",
  "displayName": "GM Global Techies Town",
  "displayNameHtml": "GM Global Techies Town",
  "loginTheme": "society-events",
  "enabled": true,
  "loginWithEmailAllowed": true,
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "rememberMe": true,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeoutRememberMe": 604800,
  "ssoSessionMaxLifespanRememberMe": 2592000,
  "refreshTokenMaxReuse": 0,
  "revokeRefreshToken": true,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "maxDeltaTimeSeconds": 43200,
  "quickLoginCheckMilliSeconds": 1000,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Society administrator \u2014 full access"
      },
      {
        "name": "committee_member",
        "description": "Can create and manage events"
      },
      {
        "name": "resident",
        "description": "Can register for events and make payments"
      },
      {
        "name": "security_guard",
        "description": "Can scan QR codes at entry"
      },
      {
        "name": "sponsor",
        "description": "External sponsor — can view sponsored events and manage refund requests"
      }
    ]
  },
  "clients": [
    {
      "clientId": "society-frontend",
