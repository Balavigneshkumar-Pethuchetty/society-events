{
  "id": "society-events",
  "realm": "society-events",
  "displayName": "Society Events Portal",
  "enabled": true,
  "loginWithEmailAllowed": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "refreshTokenMaxReuse": 0,
  "revokeRefreshToken": true,
  "bruteForceProtected": true,

  "roles": {
    "realm": [
      { "name": "admin",            "description": "Society administrator — full access" },
      { "name": "committee_member", "description": "Can create and manage events" },
      { "name": "resident",         "description": "Can register for events and make payments" },
      { "name": "security_guard",   "description": "Can scan QR codes at entry" }
    ]
  },

  "clients": [
    {
      "clientId": "society-frontend",
      "name": "Society Events — Web App",
      "description": "Public PKCE client for the React/Vue micro-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:4200/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:4200",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "society-api",
      "name": "Society Events — API Gateway",
      "description": "Confidential client for backend microservices to validate tokens",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "society-api-secret-change-in-prod",
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    }
  ],

