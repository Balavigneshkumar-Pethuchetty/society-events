# Staging environment — mirrors production layout with staging-specific credentials
# Usage: make up ENV=stage   |   make down ENV=stage
# Copy:  cp .env.stage.example .env.stage

# ─── Nginx ───────────────────────────────────────────────────────────────────
NGINX_PORT=80
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=your_stage_nginx_admin_password

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=society_user
POSTGRES_PASSWORD=your_stage_postgres_password
POSTGRES_PORT=5432

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=your_stage_keycloak_admin_password
KEYCLOAK_PUBLIC_URL=https://staging.your-domain.com
KEYCLOAK_PORT=8081
KEYCLOAK_API_CLIENT_SECRET=your_stage_api_client_secret_min_32_chars

# ─── Google OAuth — OPTIONAL ──────────────────────────────────────────────────
# Use a separate Google OAuth app pointing to the staging redirect URI:
#   https://staging.your-domain.com/realms/society-events/broker/google/endpoint
# Leave blank → Google login disabled on staging.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_stage_pgadmin_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_stage_redis_password
REDIS_PORT=6379

# ─── Application Services ─────────────────────────────────────────────────────
INTERNAL_API_KEY=your_stage_internal_api_key_min_32_chars

# ─── Society Configuration ────────────────────────────────────────────────────
SOCIETY_NAME=GM Global Techies Town (Stage)
SOCIETY_SHORT_NAME=GMGT-STAGE
SOCIETY_CITY=Bengaluru

# ─── Gmail SMTP — OPTIONAL ────────────────────────────────────────────────────
# Recommended: configure SMTP on staging to test the full email flow.
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=

# ─── Splunk — OPTIONAL ────────────────────────────────────────────────────────
SPLUNK_PORT=8000
SPLUNK_PASSWORD=
SPLUNK_HEC_TOKEN=
